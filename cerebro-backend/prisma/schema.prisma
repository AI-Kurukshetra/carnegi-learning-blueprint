}

// ============================================================
// STUDENT PROGRESS
// ============================================================

model StudentMilestone {
  id            String          @id @default(uuid()) @db.Uuid
  tenant_id     String          @db.Uuid
  student_id    String          @db.Uuid
  classroom_id  String          @db.Uuid
  created_by_id String          @db.Uuid
  title         String
  description   String?
  status        MilestoneStatus @default(NOT_STARTED)
  due_date      DateTime?       @db.Date
  completed_at  DateTime?       @db.Timestamptz
  created_at    DateTime        @default(now()) @db.Timestamptz
  updated_at    DateTime        @updatedAt @db.Timestamptz
  deleted_at    DateTime?       @db.Timestamptz

  tenant     Tenant          @relation(fields: [tenant_id], references: [id])
  student    User            @relation("StudentMilestones", fields: [student_id], references: [id])
  classroom  Classroom       @relation(fields: [classroom_id], references: [id])
  created_by User            @relation("MilestoneCreator", fields: [created_by_id], references: [id])
  tasks      MilestoneTask[]

  @@index([tenant_id, student_id], name: "idx_milestones_tenant_student")
  @@index([tenant_id, classroom_id], name: "idx_milestones_tenant_classroom")
  @@index([tenant_id, student_id, status], name: "idx_milestones_tenant_student_status")
  @@map("student_milestones")
}

model MilestoneTask {
  id              String    @id @default(uuid()) @db.Uuid
  tenant_id       String    @db.Uuid
  milestone_id    String    @db.Uuid
  student_id      String    @db.Uuid
  description     String
  completion_pct  Int?
  teacher_comment String?
  reviewed_by_id  String?   @db.Uuid
  reviewed_at     DateTime? @db.Timestamptz
  created_at      DateTime  @default(now()) @db.Timestamptz
  updated_at      DateTime  @updatedAt @db.Timestamptz

  tenant      Tenant           @relation(fields: [tenant_id], references: [id])
  milestone   StudentMilestone @relation(fields: [milestone_id], references: [id])
  student     User             @relation("TaskCreator", fields: [student_id], references: [id])
  reviewed_by User?            @relation("TaskReviewer", fields: [reviewed_by_id], references: [id])

  @@index([tenant_id, milestone_id], name: "idx_milestone_tasks_tenant_milestone")
  @@map("milestone_tasks")
}

model StudentInsightCache {
  id              String   @id @default(uuid()) @db.Uuid
  tenant_id       String   @db.Uuid
  classroom_id    String   @db.Uuid
  student_id      String   @db.Uuid
  generated_by_id String   @db.Uuid
  insight         Json     @db.JsonB
  generated_at    DateTime @default(now()) @db.Timestamptz
  created_at      DateTime @default(now()) @db.Timestamptz
  updated_at      DateTime @updatedAt @db.Timestamptz

  tenant       Tenant    @relation(fields: [tenant_id], references: [id])
  classroom    Classroom @relation(fields: [classroom_id], references: [id])
  student      User      @relation("InsightStudent", fields: [student_id], references: [id])
  generated_by User      @relation("InsightGenerator", fields: [generated_by_id], references: [id])

  @@unique([tenant_id, classroom_id, student_id], name: "uq_insight_cache_tenant_classroom_student")
  @@index([tenant_id, classroom_id, student_id], name: "idx_insight_cache_tenant_classroom_student")
  @@map("student_insight_cache")
}

model Invoice {
  id          String        @id @default(uuid()) @db.Uuid
  tenant_id   String        @db.Uuid
  amount      Decimal       @db.Decimal(10, 2)
  currency    String        @default("USD")
  status      InvoiceStatus @default(PENDING)
  due_date    DateTime      @db.Timestamptz
  paid_at     DateTime?     @db.Timestamptz
  description String?
  created_at  DateTime      @default(now()) @db.Timestamptz
  updated_at  DateTime      @updatedAt @db.Timestamptz

  tenant Tenant @relation(fields: [tenant_id], references: [id])

  @@index([tenant_id])
  @@map("invoices")
}
